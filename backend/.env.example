# ══════════════════════════════════════════════════════════════
# SMAART Career Intelligence Platform — Environment Variables
# ══════════════════════════════════════════════════════════════
#
# HOW TO USE:
# 1. Copy this file:  copy .env.example .env
# 2. Fill in YOUR values below (ask team lead for API keys)
# 3. Never commit the .env file (it's in .gitignore)
#
# ══════════════════════════════════════════════════════════════

# ── Server ──
PORT=5000

# ── PostgreSQL Database ──
# Install PostgreSQL locally, create a database called 'smaart_db'
# Format: postgres://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/smaart_db

# ── MongoDB ──
# Install MongoDB locally or use MongoDB Atlas (free tier)
# Local: mongodb://127.0.0.1:27017/smaart_db
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/smaart_db
MONGO_URI=mongodb://127.0.0.1:27017/smaart_db

# ── Redis (OPTIONAL — app works without it) ──
# Install Redis locally or skip this (caching will be disabled)
REDIS_URL=redis://localhost:6379

# ── JWT Secret (any random string for auth tokens) ──
JWT_SECRET=replace_with_any_random_string_here

# ── AI API Keys (ask team lead Vickram for these) ──
# OpenRouter: https://openrouter.ai/keys (used for career analysis)
OPENROUTER_API_KEY=sk-or-v1-PASTE_YOUR_KEY_HERE

# Groq: https://console.groq.com/keys (used for news generation)
GROQ_API_KEY=gsk_PASTE_YOUR_KEY_HERE

# ── AI Model (do not change unless told to) ──
AI_MODEL=anthropic/claude-3.5-sonnet

# ── ML Service URL (Python Flask on port 5001) ──
ML_SERVICE_URL=http://127.0.0.1:5001
